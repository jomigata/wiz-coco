rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 프로필 문서에 대한 규칙
    // - 일반 사용자는 본인 문서 읽기 가능
    // - 일반 사용자는 본인 문서 생성/수정 가능(단, role은 'user'로만 생성 가능, 수정 시 role 변경 불가)
    // - admin은 모든 문서 읽기/쓰기 가능
    match /users/{userId} {
      function isAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());

      // 최초 생성은 본인만 가능, role은 user만 허용
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == 'user';

      // 본인 업데이트는 role 변경 금지
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.role == resource.data.role;

      // admin은 어떤 문서든 수정 가능
      allow update, delete: if isAdmin();
    }

    // 상담사 공개 프로필 - counselors (내담자 연결 시 조회)
    match /counselors/{counselorId} {
      function isCounselorAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      allow read: if request.auth != null;
      allow create, update: if request.auth != null && (
        (counselorId == request.auth.uid && request.resource.data.id == request.auth.uid)
        || isCounselorAdmin()
      );
      allow delete: if false;
    }

    // 상담사 검사코드 세트 - assessments
    // 상담사는 자신의 assessment만 읽기/쓰기. 공개 조회(accessCode)는 백엔드 API에서 처리.
    match /assessments/{assessmentId} {
      allow read, list: if request.auth != null && resource.data.counselorId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.counselorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.counselorId == request.auth.uid;
    }

    // 내담자 포털 — clientPortals (코드+PIN 로그인, 백엔드 API 전용)
    match /clientPortals/{portalId} {
      allow read, write: if false;
    }

    // 통지 큐 — notificationQueue (백엔드 워커 전용)
    match /notificationQueue/{itemId} {
      allow read, write: if false;
    }

    // 검사 결과 - testResults
    // 1) 로그인 사용자(내담자)는 본인(uid) 결과를 읽고/생성 가능 (이메일 없이 앱/웹 내 조회 목적)
    // 2) 상담사는 assessment 기반 결과를 읽을 수 있음(기존 호환)
    match /testResults/{resultId} {
      function isAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      function isOwner() {
        return request.auth != null
          && resource.data.keys().hasAny(['uid'])
          && resource.data.uid == request.auth.uid;
      }

      function isOwnerCreate() {
        return request.auth != null
          && request.resource.data.keys().hasAny(['uid'])
          && request.resource.data.uid == request.auth.uid;
      }

      function isCounselorByAssessment() {
        return request.auth != null
          && resource.data.keys().hasAny(['assessmentId'])
          && exists(/databases/$(database)/documents/assessments/$(resource.data.assessmentId))
          && get(/databases/$(database)/documents/assessments/$(resource.data.assessmentId)).data.counselorId == request.auth.uid;
      }

      function isCounselorDirect() {
        return request.auth != null
          && resource.data.keys().hasAny(['counselorId'])
          && resource.data.counselorId == request.auth.uid;
      }

      // 읽기: 본인(uid) 또는 assessment 소유 상담사 또는 admin
      allow read, list: if request.auth != null && (isOwner() || isCounselorByAssessment() || isCounselorDirect() || isAdmin());

      // 생성: 본인(uid)만 허용 (서버에서 생성하는 assessment 기반 결과는 Admin SDK로 우회)
      allow create: if isOwnerCreate();

      // 업데이트: 본인(uid)만, uid 변경 금지
      allow update: if request.auth != null
        && resource.data.keys().hasAny(['uid'])
        && resource.data.uid == request.auth.uid
        && request.resource.data.uid == resource.data.uid;

      allow delete: if isAdmin();
    }

    // 상담사 인증코드 - counselorCodes (기능 종료, 클라이언트 접근 차단)
    match /counselorCodes/{codeId} {
      allow read, write: if false;
    }

    // 내담자-상담사 연결 - clientCounselorRelations
    match /clientCounselorRelations/{relationId} {
      allow read: if request.auth != null && (
        resource.data.clientId == request.auth.uid
        || resource.data.counselorId == request.auth.uid
      );

      allow create: if request.auth != null
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.isActive == true;

      allow update: if request.auth != null && (
        resource.data.clientId == request.auth.uid
        || resource.data.counselorId == request.auth.uid
      );

      allow delete: if false;
    }

    // 상담사 지원 신청 - counselorApplications
    // - 신청자: 본인 문서 생성/조회 가능 (상태는 pending으로만 생성)
    // - admin: 전체 조회/승인/반려 및 메모 수정 가능
    match /counselorApplications/{applicationId} {
      function isAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      allow read, list: if request.auth != null
        && (isAdmin() || resource.data.applicantUid == request.auth.uid);

      allow create: if request.auth != null
        && request.resource.data.applicantUid == request.auth.uid
        && request.resource.data.status == 'pending';

      allow update, delete: if request.auth != null && isAdmin();
    }

    // 멤버십 구독 - subscriptions
    // - 본인만 자신의 구독 문서 읽기/쓰기 가능
    // - admin은 전체 읽기/쓰기 가능
    match /subscriptions/{userId} {
      function isAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == userId;
      allow update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.uid == resource.data.uid;
      allow write: if isAdmin();
    }

    // 결제 이력 - paymentHistory
    // - 본인만 자신의 결제 이력 읽기 가능, 쓰기는 서버(Admin SDK)만
    match /paymentHistory/{recordId} {
      function isAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      allow read: if request.auth != null
        && (resource.data.uid == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    // 서버(Admin SDK) 전용 메타 — 클라이언트 직접 접근 차단
    match /system_meta/{docId} {
      allow read, write: if false;
    }

    // AI 상담 세션 (Gemini Functions — AiCoCo 이식)
    match /aiCounselSessions/{sessionId} {
      function isAiCounselAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }

      function canAccessAiCounselSession() {
        return request.auth != null && (
          resource.data.clientId == request.auth.uid || isAiCounselAdmin()
        );
      }

      function canAccessAiCounselSessionById() {
        let session = get(/databases/$(database)/documents/aiCounselSessions/$(sessionId));
        return request.auth != null && (
          session.data.clientId == request.auth.uid || isAiCounselAdmin()
        );
      }

      allow read: if canAccessAiCounselSession();
      allow create: if request.auth != null
        && request.resource.data.clientId == request.auth.uid
        && request.resource.data.type == 'ai'
        && request.resource.data.status in ['active', 'ended', 'escalated']
        && request.resource.data.riskLevel in ['none', 'low', 'medium', 'high'];
      allow update: if request.auth != null
        && resource.data.clientId == request.auth.uid
        && request.resource.data.clientId == resource.data.clientId
        && request.resource.data.type == resource.data.type;
      allow delete: if false;

      match /messages/{messageId} {
        allow read: if canAccessAiCounselSessionById();
        allow create: if canAccessAiCounselSessionById()
          && request.resource.data.role == 'user'
          && request.resource.data.content is string
          && request.resource.data.content.size() > 0
          && request.resource.data.content.size() <= 2000;
        allow update, delete: if false;
      }
    }

    match /crisisEvents/{eventId} {
      function isAdmin() {
        return request.auth != null
          && exists(/databases/$(database)/documents/users/$(request.auth.uid))
          && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
      }
      allow read: if isAdmin();
      allow write: if false;
    }

    match /counselFaqs/{faqId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /counselFaqMeta/{docId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // 심리검사 메뉴 검색 — 키워드·검색 로그 (클라이언트 기록, 읽기 공개)
    match /testSearchKeywords/{keywordId} {
      allow read: if true;
      allow create: if request.resource.data.normalizedTerm is string
        && request.resource.data.normalizedTerm.size() >= 1
        && request.resource.data.normalizedTerm.size() <= 80
        && request.resource.data.term is string;
      allow update: if request.resource.data.normalizedTerm == resource.data.normalizedTerm
        && request.resource.data.searchCount is int
        && request.resource.data.searchCount >= resource.data.searchCount;
    }

    match /testSearchQueries/{queryId} {
      allow create: if request.resource.data.term is string
        && request.resource.data.term.size() >= 1
        && request.resource.data.term.size() <= 100
        && request.resource.data.normalizedTerm is string
        && request.resource.data.resultCount is int;
      allow read, update, delete: if false;
    }
    
    // 다른 컬렉션에 대한 기본 규칙
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
