rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 사용자 프로필 문서에 대한 규칙
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // 상담사 검사코드 세트 - assessments
    // 상담사는 자신의 assessment만 읽기/쓰기. 공개 조회(accessCode)는 백엔드 API에서 처리.
    match /assessments/{assessmentId} {
      allow read, list: if request.auth != null && resource.data.counselorId == request.auth.uid;
      allow create: if request.auth != null && request.resource.data.counselorId == request.auth.uid;
      allow update, delete: if request.auth != null && resource.data.counselorId == request.auth.uid;
    }

    // 검사 결과 - testResults
    // 상담사는 자신의 assessment에 속한 결과만 읽기. 생성/수정/삭제는 백엔드(Flask) Admin SDK로만 처리.
    match /testResults/{resultId} {
      allow read, list: if request.auth != null
        && resource.data.keys().hasAny(['assessmentId'])
        && exists(/databases/$(database)/documents/assessments/$(resource.data.assessmentId))
        && get(/databases/$(database)/documents/assessments/$(resource.data.assessmentId)).data.counselorId == request.auth.uid;
      allow write: if false;
    }
    
    // 다른 컬렉션에 대한 기본 규칙
    match /{document=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}
