# Cloudflare Email Routing 설정 (로컬 전용, Git 제외)
# 복사: copy .env.cloudflare.example .env.cloudflare
# 실행: npm run setup:cloudflare-email

# Cloudflare API Token (권한: Zone DNS Edit, Account Email Routing Admin)
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=

# support@wizcoco.com 으로 받은 메일을 전달할 실제 주소 (인증 메일 수신 필요)
EMAIL_ROUTING_DESTINATION=jomigata@naver.com

# 선택 — 비우면 wizcoco.com zone 자동 조회
CLOUDFLARE_ZONE_NAME=wizcoco.com
