# Firebase Admin SDK (상담사 인증 + Firestore)
# 서비스 계정 JSON 파일 경로 또는 GOOGLE_APPLICATION_CREDENTIALS 사용
FIREBASE_CREDENTIALS_PATH=./serviceAccountKey.json

# 또는 JSON 내용을 base64 등으로 전달할 경우 별도 변수 사용 가능

# 이메일 발송 (상담사 승인 요청 알림 등)
# Gmail 예: SMTP_HOST=smtp.gmail.com, SMTP_PORT=587, SMTP_USER=발송계정@gmail.com
#           SMTP_PASSWORD=Google 앱 비밀번호(16자), MAIL_FROM=발송계정@gmail.com
# 프로덕션(Cloud Run): GitHub Actions Secrets → deploy-backend.yml 이 Cloud Run env 로 주입
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
MAIL_FROM=jomigata@gmail.com
COUNSELOR_ADMIN_NOTIFY_EMAIL=jomigata@gmail.com

# 내담자 초대 메일 매직 링크 베이스 URL
PUBLIC_SITE_URL=https://wizcoco.com

# 통지 큐·cohort 리마인더 Cron (POST /api/notifications/process, /cohort-reminders)
# GitHub Secret NOTIFICATION_CRON_SECRET ↔ Cloud Run env (deploy-backend.yml 자동 주입)
NOTIFICATION_CRON_SECRET=
COHORT_REMINDER_MIN_HOURS=72
INDIVIDUAL_REMINDER_MIN_HOURS=48
CARE_REMINDER_MIN_HOURS=24

# Wave 6 — Solapi 카카오 알림톡·SMS (선택, Twilio 대안)
# SOLAPI_API_KEY=
# SOLAPI_API_SECRET=
# SOLAPI_SENDER=01012345678
# SOLAPI_KAKAO_PF_ID=
# SOLAPI_KAKAO_TEMPLATE_TEST_REMINDER=
# SOLAPI_KAKAO_TEMPLATE_CARE=
# SOLAPI_KAKAO_TEMPLATE_PORTAL_CREDENTIALS=

# SMS (선택, Twilio)
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_FROM_NUMBER=

# Rate limiting (분당 요청 수, 0이면 비활성화)
RATE_LIMIT_ACCESS_CODE=30
RATE_LIMIT_PASSWORD_API=20

# Flask
FLASK_ENV=development
SECRET_KEY=change-me-in-production

# 프로덕션 CORS (Cloud Run 등) — 쉼표 구분
# CORS_ORIGINS=https://wizcoco.com,https://www.wizcoco.com,https://wiz-coco.web.app
