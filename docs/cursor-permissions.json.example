{
  "approvalMode": "unrestricted",
  "mcpAllowlist": ["*:*"],
  "terminalAllowlist": [
    "git",
    "gh",
    "npm",
    "npx",
    "firebase",
    "cross-env",
    "pnpm",
    "yarn",
    "node",
    "python",
    "py",
    "pip",
    "pip3",
    "powershell",
    "pwsh",
    "cd",
    "Set-Location",
    "pushd",
    "popd",
    "cmd",
    "where",
    "Select-Object",
    "ForEach-Object",
    "Where-Object",
    "Out-Null",
    "Sort-Object",
    "Measure-Object",
    "Get-Content",
    "Get-ChildItem",
    "Test-Path",
    "Write-Output",
    "echo"
  ]
}
